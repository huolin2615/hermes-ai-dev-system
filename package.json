{
  "name": "hermes-ai-dev-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "ai-dev": "./dist/cli.js",
    "ai-dev-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "dev": "pnpm build && node dist/cli.js",
    "test": "pnpm test:compile && node --test .test-dist/tests/*.test.js",
    "test:compile": "tsc -p tsconfig.test.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.142.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  }
}
